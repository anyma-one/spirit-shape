# Copy to .env.local for local dev, or set in your serverless host's dashboard.
#
# Phase 1 works WITHOUT this key: the result page falls back to a deterministic
# prose template. Set the key to get Claude-written prose instead.
ANTHROPIC_API_KEY=

# Optional model override for prose generation (see api/prose.ts for the default).
# ANTHROPIC_PROSE_MODEL=claude-haiku-4-5-20251001
